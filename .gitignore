# Secrets - never commit
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.keystore
credentials*
secrets*
*.secret
.zshrc.local
.gitconfig.local

# SSH and cloud credentials
id_rsa*
id_ed25519*
id_ecdsa*
.ssh/
.aws/
.gcp/

# Package manager tokens
.npmrc
.pypirc

# Machine-specific
.DS_Store

# Documentation (keep solutions/)
docs/plans/
docs/brainstorms/

# Yazi packages (installed via ya pkg)
yazi/.config/yazi/plugins/
yazi/.config/yazi/flavors/

# Tmux plugins (installed via TPM)
tmux/.config/tmux/plugins/

# Theme-managed files (regenerated by `theme` command and install.sh)
# Source of truth is themes/<name>/ directories
zellij/.config/zellij/themes/
btop/.config/btop/themes/*.theme
yazi/.config/yazi/theme.toml
gitui/.config/gitui/theme.ron
lazygit/.config/lazygit/config.yml

# Review todos (local workflow)
todos/

# OpenCode (managed outside dotfiles repo)
opencode/

# Test framework vendored deps
tests/lib/

# Local machine-only overrides
.local/

# Sisyphus workflow state
.sisyphus/

# Pi profile (untracked runtime state)
# Source of truth is pi/.pi/agent/{settings.json,settings-extensions.json,extensions/*.ts}
pi/.pi/agent/auth.json
pi/.pi/agent/sessions/
pi/.pi/agent/cache/
pi/.pi/agent/run-history.jsonl
pi/.pi/agent/*.lazypi.*.bak
pi/.pi/agent/settings.json.lazypi.*.bak
# Package-installed and Pi-managed state (regenerated from `packages` array)
pi/.pi/agent/agents/
pi/.pi/agent/skills/
pi/.pi/agent/themes/
pi/.pi/agent/git/
pi/.pi/agent/compound-engineering/
pi/.pi/agent/AGENTS.md
pi/.pi/agent/pi-cyber-ui.json
# Extensions: track *.ts source files at the top level only; exclude package install dirs
pi/.pi/agent/extensions/*/
