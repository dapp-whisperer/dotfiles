#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$HOME/dotfiles"
THEMES_DIR="$DOTFILES/themes"
CURRENT_FILE="$THEMES_DIR/current"

# ── Helpers ──────────────────────────────────────────────────────────

die() { echo "Error: $1" >&2; exit 1; }

list_themes() {
    for d in "$THEMES_DIR"/*/; do
        [[ -f "$d/manifest.toml" ]] && basename "$d"
    done
}

# Parse key = "value" from TOML manifest.
# Trailing .* in the sed pattern consumes anything after the closing quote so
# inline comments like `key = "value"  # note` don't bleed into the value.
manifest_get() {
    local file="$1" key="$2" val
    val=$(grep -F "${key} = " "$file" | head -1 | sed 's/^[^=]*= *"\([^"]*\)".*/\1/') || true
    [[ -n "$val" ]] || die "Missing manifest key '$key' in $file"
    echo "$val"
}

# Same as manifest_get but returns empty string instead of dying on missing key.
# Used for optional manifest keys so new integrations can land independently of
# per-pack retrofits.
manifest_get_optional() {
    local file="$1" key="$2" val
    val=$(grep -F "${key} = " "$file" | head -1 | sed 's/^[^=]*= *"\([^"]*\)".*/\1/' || true)
    echo "${val:-}"
}

# Parse and validate a hex color from palette.toml.
# palette.toml entries carry inline comments AND aligned whitespace (e.g.
# `background   = "#100F0F"  # note`), so:
#   - the grep regex anchors on line start with flexible whitespace before `=`
#   - the sed pattern's trailing .* consumes the inline comment
# Value is validated as ^#[0-9a-fA-F]{6}$ before return so downstream
# consumers (JSON emitter, hex_to_rgb) can trust the shape.
palette_get() {
    local file="$1" key="$2" val
    val=$(grep -E "^${key}[[:space:]]*=" "$file" | head -1 | sed 's/^[^=]*= *"\([^"]*\)".*/\1/') || true
    [[ -n "$val" ]] || die "Missing palette key '$key' in $file"
    [[ "$val" =~ ^#[0-9a-fA-F]{6}$ ]] || die "Invalid hex '$val' for key '$key' in $file"
    echo "$val"
}

# Convert #RRGGBB to "R, G, B" — the tuple form Chrome theme JSON expects
# inside color arrays (e.g., "frame": [39, 40, 34]).
hex_to_rgb() {
    local hex="${1#'#'}"
    echo "$((16#${hex:0:2})), $((16#${hex:2:2})), $((16#${hex:4:2}))"
}

# Validate that a value contains only safe characters (alphanumeric, spaces, hyphens, underscores, dots)
validate_value() {
    local val="$1" label="$2"
    [[ "$val" =~ ^[a-zA-Z0-9_.()\ -]+$ ]] || die "Invalid manifest value for '$label': $val"
}

validate_hex() {
    local val="$1" label="$2"
    [[ "$val" =~ ^[a-fA-F0-9]{6}$ ]] || die "Invalid hex color for '$label': $val"
}

# Inode-preserving sed: macOS sed -i creates a NEW file (new inode), which
# breaks file watchers in Ghostty, Zellij, Helix, btop, etc. Instead, read
# the file into memory, apply the sed pattern, and write back to the same fd.
sed_inplace() {
    local pattern="$1" file="$2"
    local content
    content="$(sed "$pattern" "$file")"
    printf '%s\n' "$content" > "$file"
}

# Sed helper for common key = "value" pattern
replace_quoted() {
    local key="$1" value="$2" file="$3"
    sed_inplace "s/^${key} = \"[^\"]*\"/${key} = \"${value}\"/" "$file"
}

# Inode-preserving file copy: cp creates a new file, breaking file watchers.
# cat src > dst writes into the existing dst inode.
copy_over() {
    local src="$1" dst="$2"
    if [[ -f "$dst" ]]; then
        cat "$src" > "$dst"
    else
        cp "$src" "$dst"
    fi
}

# ── No args: show status ────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    current="(none)"
    [[ -f "$CURRENT_FILE" ]] && current="$(tr -d '[:space:]' < "$CURRENT_FILE")"
    echo "Current theme: $current"
    echo ""
    echo "Available themes:"
    for t in $(list_themes); do
        marker="  "
        [[ "$t" == "$current" ]] && marker="* "
        name=$(manifest_get "$THEMES_DIR/$t/manifest.toml" "name")
        echo "  ${marker}${t}  ($name)"
    done
    exit 0
fi

# ── Switch theme ────────────────────────────────────────────────────

THEME="$1"
[[ "$THEME" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid theme name (only alphanumeric, hyphens, underscores allowed)"

THEME_DIR="$THEMES_DIR/$THEME"

# Validate theme exists
[[ -d "$THEME_DIR" ]] || die "Theme '$THEME' not found. Run 'theme' to list available themes."
[[ -f "$THEME_DIR/manifest.toml" ]] || die "Theme '$THEME' is missing manifest.toml"

# Parse manifest
MANIFEST="$THEME_DIR/manifest.toml"
DISPLAY_NAME=$(manifest_get "$MANIFEST" "name")
VARIANT=$(manifest_get "$MANIFEST" "variant")
GHOSTTY_NAME=$(manifest_get "$MANIFEST" "ghostty")
HELIX_NAME=$(manifest_get "$MANIFEST" "helix")
ZELLIJ_NAME=$(manifest_get "$MANIFEST" "zellij")
BTOP_NAME=$(manifest_get "$MANIFEST" "btop")
NVIM_NAME=$(manifest_get "$MANIFEST" "neovim")
DELTA_FEAT=$(manifest_get "$MANIFEST" "delta")
BAT_NAME=$(manifest_get "$MANIFEST" "bat")
TMUX_NAME=$(manifest_get "$MANIFEST" "tmux")
OPENCODE_NAME=$(manifest_get "$MANIFEST" "opencode")
WEZTERM_NAME=$(manifest_get "$MANIFEST" "wezterm")
WEZTERM_FONT=$(manifest_get "$MANIFEST" "wezterm_font")
WEZTERM_BG=$(manifest_get "$MANIFEST" "wezterm_bg")
FONT_NAME=$(manifest_get "$MANIFEST" "font")
TYPORA_NAME=$(manifest_get_optional "$MANIFEST" "typora")

# Validate all parsed values
validate_value "$DISPLAY_NAME" "name"
validate_value "$VARIANT" "variant"
validate_value "$GHOSTTY_NAME" "ghostty"
validate_value "$HELIX_NAME" "helix"
validate_value "$ZELLIJ_NAME" "zellij"
validate_value "$BTOP_NAME" "btop"
validate_value "$NVIM_NAME" "neovim"
validate_value "$DELTA_FEAT" "delta"
validate_value "$BAT_NAME" "bat"
validate_value "$TMUX_NAME" "tmux"
validate_value "$OPENCODE_NAME" "opencode"
validate_value "$WEZTERM_NAME" "wezterm"
validate_hex "$WEZTERM_BG" "wezterm_bg"
validate_value "$FONT_NAME" "font"
[[ -n "$TYPORA_NAME" ]] && validate_value "$TYPORA_NAME" "typora"

# Sed replacements on stow source files (inode-preserving for live reload)
replace_quoted "theme" "$GHOSTTY_NAME" "$DOTFILES/ghostty/.config/ghostty/config"
replace_quoted "font-family" "$FONT_NAME" "$DOTFILES/ghostty/.config/ghostty/config"
replace_quoted "theme" "$HELIX_NAME" "$DOTFILES/helix/.config/helix/config.toml"
replace_quoted "color_theme" "$BTOP_NAME" "$DOTFILES/btop/.config/btop/btop.conf"

sed_inplace "s/^theme \".*\"/theme \"${ZELLIJ_NAME}\"/" \
    "$DOTFILES/zellij/.config/zellij/config.kdl"

sed_inplace "s/colorscheme = \".*\"/colorscheme = \"${NVIM_NAME}\"/" \
    "$DOTFILES/nvim/.config/nvim/lua/plugins/colorscheme.lua"

sed_inplace "s/^	features = .*/	features = ${DELTA_FEAT}/" \
    "$DOTFILES/git/.gitconfig"

sed_inplace "s/^--theme=\".*\"/--theme=\"${BAT_NAME}\"/" \
    "$DOTFILES/bat/.config/bat/config"

# Yazi glow flag: variant-aware (dark/light)
sed_inplace "s/-s=[a-z]*/-s=${VARIANT}/" \
    "$DOTFILES/yazi/.config/yazi/yazi.toml"

# tmux: swap catppuccin flavor name
sed_inplace "s/@catppuccin_flavor '.*'/@catppuccin_flavor '${TMUX_NAME}'/" \
    "$DOTFILES/tmux/.config/tmux/tmux.conf"

# opencode: swap theme in JSON config
sed_inplace "s/\"theme\": \"[^\"]*\"/\"theme\": \"${OPENCODE_NAME}\"/" \
    "$DOTFILES/opencode/.config/opencode/opencode.json"

# WezTerm: color scheme, background overlay color, and font
sed_inplace "s/config\.color_scheme = '[^']*'/config.color_scheme = '${WEZTERM_NAME}'/" \
    "$DOTFILES/wezterm/.config/wezterm/wezterm.lua"

sed_inplace "s/Color = '#[^']*'/Color = '#${WEZTERM_BG}'/" \
    "$DOTFILES/wezterm/.config/wezterm/wezterm.lua"

sed_inplace "s/^config\.font = .*/config.font = ${WEZTERM_FONT}/" \
    "$DOTFILES/wezterm/.config/wezterm/wezterm.lua"

# Full file replacements (inode-preserving for stow symlink targets)
if [[ -d "$DOTFILES/gitui/.config/gitui" && -f "$THEME_DIR/gitui-theme.ron" ]]; then
    copy_over "$THEME_DIR/gitui-theme.ron" "$DOTFILES/gitui/.config/gitui/theme.ron"
fi

# LazyGit: concatenate base behavioral config + theme color overlay
# Write to temp first to avoid truncating config on interrupt
cat "$DOTFILES/lazygit/base-config.yml" "$THEME_DIR/lazygit-theme.yml" \
    > "$DOTFILES/lazygit/.config/lazygit/config.yml.tmp"
cat "$DOTFILES/lazygit/.config/lazygit/config.yml.tmp" \
    > "$DOTFILES/lazygit/.config/lazygit/config.yml"
rm -f "$DOTFILES/lazygit/.config/lazygit/config.yml.tmp"

# LazyDocker: same concat pattern as LazyGit
cat "$DOTFILES/lazydocker/base-config.yml" "$THEME_DIR/lazydocker-theme.yml" \
    > "$DOTFILES/lazydocker/.config/lazydocker/config.yml.tmp"
cat "$DOTFILES/lazydocker/.config/lazydocker/config.yml.tmp" \
    > "$DOTFILES/lazydocker/.config/lazydocker/config.yml"
rm -f "$DOTFILES/lazydocker/.config/lazydocker/config.yml.tmp"

if [[ -f "$THEME_DIR/zellij-colors.kdl" ]]; then
    mkdir -p "$DOTFILES/zellij/.config/zellij/themes"
    copy_over "$THEME_DIR/zellij-colors.kdl" "$DOTFILES/zellij/.config/zellij/themes/${ZELLIJ_NAME}.kdl"
fi

if [[ -f "$THEME_DIR/btop.theme" ]]; then
    mkdir -p "$DOTFILES/btop/.config/btop/themes"
    copy_over "$THEME_DIR/btop.theme" "$DOTFILES/btop/.config/btop/themes/${BTOP_NAME}.theme"
fi

# Restow packages that may have new theme files (stow won't symlink files
# added after the initial stow run without a restow)
(cd "$DOTFILES" && stow -R btop zellij wezterm)

if [[ -f "$THEME_DIR/yazi-theme.toml" ]]; then
    copy_over "$THEME_DIR/yazi-theme.toml" "$DOTFILES/yazi/.config/yazi/theme.toml"
fi

# tmux: install custom flavor file for non-catppuccin themes
if [[ -f "$THEME_DIR/tmux-theme.conf" ]]; then
    TMUX_PLUGIN_THEMES="$HOME/.config/tmux/plugins/tmux/themes"
    if [[ -d "$TMUX_PLUGIN_THEMES" ]]; then
        copy_over "$THEME_DIR/tmux-theme.conf" "$TMUX_PLUGIN_THEMES/catppuccin_${TMUX_NAME}_tmux.conf"
    fi
fi

# tmux: install theme colors for outer status bar
if [[ -f "$THEME_DIR/tmux-theme.conf" ]]; then
    cp "$THEME_DIR/tmux-theme.conf" "$HOME/.config/tmux/current-theme.conf"
fi

# Copy to non-stow destinations (not symlinked, cp is fine)
mkdir -p "$HOME/.config/delta"
cp "$THEME_DIR/delta.gitconfig" "$HOME/.config/delta/theme.gitconfig"

mkdir -p "$HOME/.config/fzf"
cp "$THEME_DIR/fzf-theme.sh" "$HOME/.config/fzf/theme.sh"

mkdir -p "$HOME/.config/bat/themes"
cp "$THEME_DIR/bat.tmTheme" "$HOME/.config/bat/themes/${BAT_NAME}.tmTheme"

mkdir -p "$HOME/.config/eza"
cp "$THEME_DIR/eza-theme.yml" "$HOME/.config/eza/theme.yml"

# Typora: copy CSS to Typora's themes directory and update both `theme` and
# `darkTheme` defaults so the active pack renders regardless of Typora's
# useSeparateDarkTheme state. Optional: packs without `typora` skip silently.
# THEME_TYPORA_APP / THEME_TYPORA_THEMES env vars allow test isolation.
if [[ "$OSTYPE" == "darwin"* && -n "$TYPORA_NAME" && -f "$THEME_DIR/typora-theme.css" ]]; then
    TYPORA_THEMES="${THEME_TYPORA_THEMES:-$HOME/Library/Application Support/abnerworks.Typora/themes}"
    TYPORA_APP="${THEME_TYPORA_APP:-/Applications/Typora.app}"
    if [[ -d "$TYPORA_THEMES" || -d "$TYPORA_APP" ]]; then
        mkdir -p "$TYPORA_THEMES"
        cp "$THEME_DIR/typora-theme.css" "$TYPORA_THEMES/${TYPORA_NAME}.css"
        defaults write abnerworks.Typora theme "$DISPLAY_NAME" 2>/dev/null || true
        defaults write abnerworks.Typora darkTheme "$DISPLAY_NAME" 2>/dev/null || true
    fi
fi

# cmux: app chrome + built-in browser theme follow the pack's variant.
# Reuses the existing variant key, so every pack works without retrofit.
# THEME_CMUX_APP env var allows test isolation.
CMUX_APP="${THEME_CMUX_APP:-/Applications/cmux.app}"
if [[ "$OSTYPE" == "darwin"* && -d "$CMUX_APP" ]]; then
    defaults write com.cmuxterm.app appearanceMode "$VARIANT" 2>/dev/null || true
    defaults write com.cmuxterm.app browserThemeMode "$VARIANT" 2>/dev/null || true
fi

# Brave Browser: generate a Chrome theme extension from palette.toml and edit
# the NTP background preference. Gated on palette.toml existence — packs
# without it skip silently, matching the optional-integration pattern used by
# Typora / cmux. THEME_BRAVE_EXT / THEME_BRAVE_PREFS env vars allow test isolation.
PALETTE="$THEME_DIR/palette.toml"
if [[ -f "$PALETTE" ]]; then
    BG=$(palette_get "$PALETTE" "background")
    FG=$(palette_get "$PALETTE" "foreground")
    SURF=$(palette_get "$PALETTE" "surface")
    SURF_DARK=$(palette_get "$PALETTE" "surface_dark")
    CMT=$(palette_get "$PALETTE" "comment")
    # accent is parsed so palette.toml is fully validated, even though the
    # Chrome theme slots don't currently consume it; future slots (e.g.
    # bookmark highlight) can reference $ACC without reparsing.
    ACC=$(palette_get "$PALETTE" "accent")

    # Pre-compute RGB tuples outside the heredoc — subshell failures inside
    # heredoc $() expansions are silently swallowed by set -euo pipefail, so
    # any hex_to_rgb error must abort before the JSON file is written.
    RGB_BG=$(hex_to_rgb "$BG")
    RGB_FG=$(hex_to_rgb "$FG")
    RGB_SURF=$(hex_to_rgb "$SURF")
    RGB_SURF_DARK=$(hex_to_rgb "$SURF_DARK")
    RGB_CMT=$(hex_to_rgb "$CMT")

    # ntp_* keys are deliberately omitted: Brave's new tab page ignores Chrome
    # theme NTP colors (brave-browser#29409, #34304). NTP background is set
    # via the Preferences edit below instead.
    # $THEME is safe to interpolate into JSON: validated ^[a-zA-Z0-9_-]+$ above.
    BRAVE_EXT="${THEME_BRAVE_EXT:-$HOME/.config/brave-theme/current}"
    mkdir -p "$BRAVE_EXT"
    MANIFEST_TMP="$(mktemp)"
    cat > "$MANIFEST_TMP" << EOF
{
  "manifest_version": 3,
  "version": "1.0",
  "name": "$THEME",
  "theme": {
    "colors": {
      "frame":               [$RGB_BG],
      "frame_inactive":      [$RGB_SURF_DARK],
      "toolbar":             [$RGB_SURF],
      "toolbar_text":        [$RGB_FG],
      "toolbar_button_icon": [$RGB_FG],
      "tab_text":            [$RGB_FG],
      "tab_background_text": [$RGB_CMT],
      "background_tab":      [$RGB_SURF_DARK],
      "omnibox_background":  [$RGB_SURF_DARK],
      "omnibox_text":        [$RGB_FG],
      "bookmark_text":       [$RGB_FG]
    }
  }
}
EOF
    # Validate JSON before replacing the live file — prevents a malformed
    # manifest.json from bricking Brave's theme load.
    if ! python3 -m json.tool "$MANIFEST_TMP" > /dev/null 2>&1; then
        rm -f "$MANIFEST_TMP"
        die "Generated Brave manifest.json is invalid JSON — aborting"
    fi
    mv "$MANIFEST_TMP" "$BRAVE_EXT/manifest.json"

    # NTP background lives in Brave's Preferences JSON. Brave holds Preferences
    # in memory and rewrites on clean exit, so edits made while Brave is running
    # are silently lost. pgrep -qx matches the exact process name to avoid
    # false-positives on "Brave Browser Helper" processes.
    BRAVE_PREFS="${THEME_BRAVE_PREFS:-$HOME/Library/Application Support/BraveSoftware/Brave-Browser/Default/Preferences}"
    if [[ -f "$BRAVE_PREFS" ]]; then
        if pgrep -qx "Brave Browser" 2>/dev/null; then
            echo "  ⚠  Brave is running — NTP background not updated. Quit Brave and re-run 'theme $THEME' to apply."
        else
            PREFS_TMP="$(mktemp)"
            if jq --arg bg "$BG" \
                '.brave.new_tab_page.background = {"type":"color","random":false,"selected_value":$bg}' \
                "$BRAVE_PREFS" > "$PREFS_TMP" 2>/dev/null; then
                mv "$PREFS_TMP" "$BRAVE_PREFS"
            else
                rm -f "$PREFS_TMP"
            fi
        fi
    fi
fi

# Live reloads (best-effort, non-fatal)
bat cache --build 2>/dev/null || true

# Neovim RPC reload
for sock in "${XDG_RUNTIME_DIR:-/tmp}"/nvim-*.sock /tmp/nvim-*/0 ; do
    [[ -S "$sock" ]] && nvim --server "$sock" --remote-send ":colorscheme ${NVIM_NAME}<CR>" 2>/dev/null || true
done

# Ghostty: file watching doesn't trigger through stow symlinks on macOS,
# so we use AppleScript to invoke the "Reload Configuration" menu action.
if pgrep -q ghostty 2>/dev/null; then
    osascript -e '
        tell application "System Events"
            tell process "ghostty"
                click menu item "Reload Configuration" of menu 1 of menu bar item "Ghostty" of menu bar 1
            end tell
        end tell
    ' 2>/dev/null || true
fi

# tmux: source config to reload theme
tmux source-file ~/.config/tmux/tmux.conf 2>/dev/null || true

# Also update inner tmux sessions
sed_inplace "s/@catppuccin_flavor '.*'/@catppuccin_flavor '${TMUX_NAME}'/" \
    "$DOTFILES/tmux/.config/tmux/inner.conf"
tmux -L inner source-file ~/.config/tmux/inner.conf 2>/dev/null || true

# Zellij, Helix: auto-reload on config file change (inode-preserving writes trigger this)

# Write current LAST (signals complete application)
echo "$THEME" > "$CURRENT_FILE"

# Print summary
echo "Switched to: $DISPLAY_NAME ($FONT_NAME)"
echo ""
echo "Auto-reloaded: Ghostty, WezTerm, Zellij, Helix, Neovim, tmux, bat"
restart_line="btop, lazygit, lazydocker, yazi, opencode, Typora, cmux"
[[ -f "$PALETTE" ]] && restart_line="${restart_line}, Brave Browser"
echo "Restart needed: $restart_line"
echo "Reload fzf in this shell: source ~/.config/fzf/theme.sh"
